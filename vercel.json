{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/studio/:path*",
      "destination": "https://ogundigitalsummit.sanity.studio/:path*"
    },
    {
      "source": "/studio",
      "destination": "https://ogundigitalsummit.sanity.studio"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
